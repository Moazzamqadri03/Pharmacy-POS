// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  relationMode = "prisma"
}

model Medicine {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  price     Float
  stock     Int      @default(0)
  gstRate   Float    @default(5)
  purchasePrice Float?
  unitsPurchased Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems SaleItem[]
}

model Sale {
  id          Int      @id @default(autoincrement())
  invoiceNo   String   @unique
  customerName String?
  customerPhone String?
  doctorName  String?
  discount    Float    @default(0)
  subtotal    Float
  cgst        Float
  sgst        Float
  grandTotal  Float
  createdAt   DateTime @default(now())

  items SaleItem[]
}

model SaleItem {
  id         Int      @id @default(autoincrement())
  saleId     Int
  medicineId Int
  medicineName String
  qty        Int
  unitPrice  Float
  gstRate    Float
  lineTotal  Float

  sale     Sale     @relation(fields: [saleId], references: [id])
  medicine Medicine @relation(fields: [medicineId], references: [id])
}

model User {
  id           Int          @id @default(autoincrement())
  name         String?
  email        String?      @unique
  phone        String?      @unique
  passwordHash String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  otpRequests  OtpRequest[]
  sessions     Session[]
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model OtpRequest {
  id         Int      @id @default(autoincrement())
  userId     Int
  method     String
  identifier String
  purpose    String
  code       String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  @@index([identifier, purpose, code])
}
